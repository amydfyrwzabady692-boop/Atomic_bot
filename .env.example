# توکن ربات تلگرام
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# دیتابیس PostgreSQL (همان دیتابیس سایت AccShop)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=accshop
DB_USER=postgres
DB_PASSWORD=postgres

# زرین‌پال
ZARINPAL_MERCHANT_ID=your-merchant-uuid
ZARINPAL_SANDBOX=0

# دامنه عمومی ربات (DNS باید به IP وی‌پی‌اس اشاره کند)
BOT_DOMAIN=bot.atomicshop.ir

# آدرس callback درگاه — از طریق پروکسی Caddy روی همین دامنه
# نباید اسلش انتهایی داشته باشد
PAYMENT_CALLBACK_BASE=https://bot.atomicshop.ir
WEB_PORT=8080

# G2Bulk — تحویل خودکار جم
G2BULK_API_KEY=
G2BULK_GAME_CODE=freefire_me

# کارت‌به‌کارت
CARD_TRANSFER_NUMBER=6219861997831192
CARD_TRANSFER_HOLDER=امید فیروزآبادی
CARD_TRANSFER_BANK=سامان

# آیدی عددی تلگرام ادمین (برای دریافت رسید و دکمه تایید/رد)
ADMIN_CHAT_ID=
